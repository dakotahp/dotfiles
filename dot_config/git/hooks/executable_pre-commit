#!/bin/bash

currentBranch="$(git rev-parse --abbrev-ref HEAD)"

if [[ "$currentBranch" != "master" && "$currentBranch" != "main" ]]; then
  exit 0
fi

# Per-repo opt-out: git config hooks.allowMasterCommit true
if [[ "$(git config --bool hooks.allowMasterCommit 2>/dev/null)" == "true" ]]; then
  exit 0
fi

# Non-interactive fallback: no controlling terminal available (CI, scripts, etc.)
if ! exec < /dev/tty 2>/dev/null; then
  echo "ERROR: Committing directly to $currentBranch is not allowed in non-interactive mode."
  echo "To allow this in this repo, run: git config hooks.allowMasterCommit true"
  exit 1
fi

echo "You are about to commit to $currentBranch. Are you sure? [yes/No]"

while read -n 1 -r yn; do
  if [ "$yn" = "" ]; then
      yn='N'
  fi
  case $yn in
      [Yy] ) break;;
      [Nn] ) echo;[[ "$0" = "$BASH_SOURCE" ]] && exit 1 || return 1;;
      * ) echo "Please answer y (yes) or n (no):" && continue;
  esac
done

exec <&-
