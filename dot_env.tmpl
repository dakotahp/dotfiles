# Set environment variables

# 1Password-sourced env vars
_load_op_secrets() {
  export WEATHER_LAT_LONG=$(op read "op://Private/Weather API lat-long and TZ/lat-long")
  export WEATHER_TZ=$(op read "op://Private/Weather API lat-long and TZ/timezone")
}

if [[ -z "$SSH_TTY" ]]; then
  _load_op_secrets 2>/dev/null
elif op whoami >/dev/null 2>&1; then
  _load_op_secrets
fi

{{ if eq .chezmoi.os "linux" -}}
# 1Password SSH agent on linux
export SSH_AUTH_SOCK=~/.1password/agent.sock
{{ end -}}

{{ if eq .chezmoi.os "darwin" -}}
# Convince MacOS to use ~/.config/ instead of ~/Library/Application Support/
export XDG_CONFIG_HOME="$HOME/.config"
{{ end -}}
